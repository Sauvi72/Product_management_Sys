<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Product</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<div class="form-container">
    <h1>Add New Product</h1>

    <form action="/add" method="POST">
        <label>Product Name</label>
        <input type="text" name="name" placeholder="Enter Product Name" required>

        <label>Category</label>
        <input type="text" name="category" placeholder="Enter Category" required>

        <label>Company</label>
        <input type="text" name="company" placeholder="Enter Company Name" required>

        <label>Price</label>
        <input type="number" name="price" placeholder="Enter Price" min="0" required>

        <label>Stock</label>
        <input type="number" name="stock" placeholder="Enter Stock" min="0" required>

        <button type="submit" class="btn add-btn">Add Product</button>
    </form>
    <br>
    <a href="/" class="btn">Back to Home</a>
</div>

</body>
</html>